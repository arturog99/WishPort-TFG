<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8FAFC"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Detalle de Reserva"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <!-- CARD INFO -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:elevation="6dp"
            android:background="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Información de la Reserva"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1F3A5F"
                    android:layout_marginBottom="16dp"/>

                <!-- Deporte -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Deporte: "
                        android:textStyle="bold"
                        android:textColor="#0F172A"/>

                    <TextView
                        android:id="@+id/tvDeporte"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#475569"/>
                </LinearLayout>

                <!-- Pista -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pista: "
                        android:textStyle="bold"
                        android:textColor="#0F172A"/>

                    <TextView
                        android:id="@+id/tvPista"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#475569"/>
                </LinearLayout>

                <!-- Fecha -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fecha: "
                        android:textStyle="bold"
                        android:textColor="#0F172A"/>

                    <TextView
                        android:id="@+id/tvFecha"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#475569"/>
                </LinearLayout>

                <!-- Hora -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hora: "
                        android:textStyle="bold"
                        android:textColor="#0F172A"/>

                    <TextView
                        android:id="@+id/tvHora"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#475569"/>
                </LinearLayout>

                <!-- Estado -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Estado: "
                        android:textStyle="bold"
                        android:textColor="#0F172A"/>

                    <TextView
                        android:id="@+id/tvEstado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#1F3A5F"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- ID -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reserva #: "
                        android:textStyle="bold"
                        android:textColor="#0F172A"/>

                    <TextView
                        android:id="@+id/tvIdReserva"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#475569"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- QR CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:elevation="6dp"
            android:background="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Código QR de Acceso"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1F3A5F"
                    android:layout_marginBottom="16dp"/>

                <ImageView
                    android:id="@+id/ivCodigoQR"
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:background="#F1F5F9"
                    android:scaleType="fitCenter"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Muestra este código en la entrada"
                    android:textSize="13sp"
                    android:textColor="#64748B"
                    android:layout_marginTop="12dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- BOTONES -->
        <Button
            android:id="@+id/btnCancelarReserva"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Cancelar Reserva"
            android:textColor="#FFFFFF"
            android:backgroundTint="#EF4444"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnVolverReservas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Volver a mis reservas"
            android:layout_marginTop="12dp"
            style="?attr/materialButtonOutlinedStyle"
            android:textColor="#1F3A5F"
            android:strokeColor="#CBD5E1"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginTop="16dp"/>

    </LinearLayout>

</ScrollView>