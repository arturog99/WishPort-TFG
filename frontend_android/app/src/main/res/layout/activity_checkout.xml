<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="true"
    android:background="#F8FAFC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- TÍTULO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resumen de tu reserva"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:layout_marginBottom="16dp"/>

        <!-- CARD RESUMEN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="4dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvResumenPista"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#0F172A"/>

            <TextView
                android:id="@+id/tvResumenFechaHora"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#475569"
                android:layout_marginTop="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total a pagar: 12.00 €"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1F3A5F"
                android:gravity="end"
                android:layout_marginTop="16dp"/>
        </LinearLayout>

        <!-- TITULO PAGO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Datos de pago"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:layout_marginBottom="12dp"/>

        <!-- INPUTS -->
        <EditText
            android:id="@+id/etTitular"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Titular de la tarjeta"
            android:backgroundTint="#CBD5E1"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etNumTarjeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Número de tarjeta (16 dígitos)"
            android:inputType="number"
            android:maxLength="16"
            android:backgroundTint="#CBD5E1"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <EditText
                android:id="@+id/etCaducidad"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="MM/AA"
                android:backgroundTint="#CBD5E1"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/etCVV"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="CVV"
                android:inputType="numberPassword"
                android:maxLength="3"
                android:backgroundTint="#CBD5E1"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- BOTÓN PAGO -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPagar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="CONFIRMAR Y PAGAR (12.00 €)"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1F3A5F"
            app:cornerRadius="12dp"/>

        <!-- CANCELAR -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelarCheckout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cancelar"
            android:layout_marginTop="8dp"
            style="?attr/materialButtonOutlinedStyle"
            android:textColor="#1F3A5F"
            app:strokeColor="#CBD5E1"
            app:cornerRadius="12dp"/>

        <!-- LOADING -->
        <ProgressBar
            android:id="@+id/progressBarPago"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:visibility="gone"/>

    </LinearLayout>

</FrameLayout>